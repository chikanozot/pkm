# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: O URL do projeto do Supabase para persistir dados.
SUPABASE_URL=""

# SUPABASE_ANON_KEY: A chave anônima (anon key) do Supabase.
SUPABASE_ANON_KEY=""

# SUPABASE_SERVICE_ROLE_KEY: A chave de serviço do Supabase (Service Role Key) para operações do lado do servidor (como sincronização automática em segundo plano ignorando RLS).
SUPABASE_SERVICE_ROLE_KEY=""

# GOOGLE_CLIENT_ID: O ID do cliente OAuth do Google para sincronização de calendário.
GOOGLE_CLIENT_ID=""

# GOOGLE_CLIENT_SECRET: A chave secreta de OAuth do Google.
GOOGLE_CLIENT_SECRET=""

# STRIPE_SECRET_KEY: A chave secreta do Stripe (sk_live_... ou sk_test_...) para autenticação das chamadas de API do lado do servidor.
STRIPE_SECRET_KEY=""

# STRIPE_WEBHOOK_SECRET: O segredo de assinatura do webhook do Stripe (whsec_...) para validar a autenticidade das requisições.
STRIPE_WEBHOOK_SECRET=""

# STRIPE_PRICE_BRONZE: ID de preço recorrente do Plano Bronze no Stripe (opcional, senão cria dinamicamente)
STRIPE_PRICE_BRONZE=""

# STRIPE_PRICE_PRATA: ID de preço recorrente do Plano Prata no Stripe (opcional)
STRIPE_PRICE_PRATA=""

# STRIPE_PRICE_OURO: ID de preço recorrente do Plano Ouro no Stripe (opcional)
STRIPE_PRICE_OURO=""
