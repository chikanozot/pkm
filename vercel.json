{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/functions/v1/stripe-webhook",
      "destination": "/api/index.ts"
    },
    {
      "source": "/auth/google/callback",
      "destination": "/api/index.ts"
    },
    {
      "source": "/auth/google/callback/",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|auth/google/callback).*)",
      "destination": "/index.html"
    }
  ]
}
